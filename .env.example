# ── Discord ───────────────────────────────────────────────────────────────────
# Your Discord Bot Token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ID of the Discord channel where commands are permitted (set to 0 to allow all)
ALLOWED_CHANNEL_ID=0

# ── Google Gemini AI (Vertex AI) ──────────────────────────────────────────────
GOOGLE_PROJECT_ID=your_google_project_id
GOOGLE_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Sender Gmail address (your Google Workspace account)
GMAIL_USER=your_email@gmail.com

# 16-character App Password from Google Account → Security → App Passwords
GMAIL_APP_PASSWORD=your_app_password_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The spreadsheet ID from the URL
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Path to your Google Cloud service account JSON key file
GOOGLE_SHEETS_CREDENTIALS_FILE=google_credentials.json

# Name of the tab/sheet to log into
SHEETS_TAB_NAME=Outreach Log

# ─── HAUL-E TMS — Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in the values

# ─── Database ─────────────────────────────────────────────────────────────────
# For local dev (SQLite fallback): leave empty or use sqlite+aiosqlite:///tms.db
# For production (PostgreSQL): postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///tms.db

# ─── Discord Bot ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
ALLOWED_CHANNEL_ID=0

# ─── Google Cloud / Gemini AI ─────────────────────────────────────────────────
GOOGLE_PROJECT_ID=haul-e-498411
GOOGLE_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CREDENTIALS_FILE=google_credentials.json

# ─── Gmail (SMTP) ────────────────────────────────────────────────────────────
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ─── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=your_google_sheets_id
GOOGLE_SHEETS_CREDENTIALS_FILE=google_credentials.json
SHEETS_TAB_NAME=Outreach Log

# ─── API Service ──────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000

# ─── Dashboard ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
